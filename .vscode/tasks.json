{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-build-debug",
            "type": "shell",
            "command": "cmake -S app -B app/build -DCMAKE_BUILD_TYPE=Debug && cmake --build app/build --parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}
